{
  "name": "tomni",
  "version": "0.1.0",
  "type": "module",
  "description": "Count and inspect token IDs across several modern tokenizer families offline.",
  "keywords": [
    "bpe",
    "count-tokens",
    "deepseek",
    "gemma",
    "gpt",
    "kimi",
    "llm",
    "minimax",
    "qwen",
    "sdxl",
    "tokenizer"
  ],
  "funding": "https://github.com/sponsors/Jaid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jaid/tomni.git"
  },
  "exports": {
    ".": {
      "types": "./src/main.ts",
      "default": "./src/main.ts"
    }
  },
  "imports": {
    "#src/*": "./src/*",
    "#root/*": "./*"
  },
  "scripts": {
    "build": "bun scripts/build.ts"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-config-jaid": "^26.0.0",
    "fs-extra": "^11.3.5",
    "tsconfig-jaid-bun": "^15.2.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "data",
    "dist",
    "src",
    "license.txt",
    "readme.md"
  ]
}